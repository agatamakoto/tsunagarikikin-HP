# microCMS API settings
# Copy this file to .env.local and set your real values.
# Preferred: set service domain
MICROCMS_SERVICE_DOMAIN=your-service-domain
# Optional legacy style (only if you are not using service domain)
# MICROCMS_API_URL=https://your-service.microcms.io/api/v1
MICROCMS_API_KEY=your_microcms_api_key

