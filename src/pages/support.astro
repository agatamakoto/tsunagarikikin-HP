---
// src/pages/support.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { client } from '../lib/microcms';
import type { Grant } from '../lib/microcms';

let grantsList: Grant[] = [];
try {
  const grantsData = await client.get({ endpoint: 'grants', queries: { limit: 100 } });
  grantsList = grantsData.contents;
} catch (e) {}

const openGrants   = grantsList.filter(g => (Array.isArray(g.status) ? g.status : [g.status as unknown as string]).includes('募集中'));
const closedGrants = grantsList.filter(g => (Array.isArray(g.status) ? g.status : [g.status as unknown as string]).includes('終了'));

function statusLabel(grant: Grant): string | null {
  const s = Array.isArray(grant.status) ? grant.status[0] : (grant.status as unknown as string);
  return s || null;
}
---

<Layout title="助成や支援を受ける" description="つながり基金の助成や伴走支援プログラムについて">
  <Header />
  
  <main>
    <div class="container page-content">
      <h1>助成や支援を受ける</h1>

      <section class="section section-programs">
        <div class="section-header">
          <div>
            <h2>助成プログラム一覧</h2>
          </div>
        </div>

        <!-- 募集中 -->
        <h3 class="grants-subheading">現在募集中</h3>
        {openGrants.length > 0 ? (
          <div class="grants-group" id="open-grants">
            <div class="card-grid">
              {openGrants.map((grant, i) => {
                const label = statusLabel(grant);
                const Tag = grant.url ? 'a' : 'article';
                return (
                  <Tag
                    class={`program-card${i >= 3 ? ' grant-hidden' : ''}`}
                    {...(grant.url ? { href: grant.url, target: '_blank', rel: 'noreferrer' } : {})}
                  >
                    <div class="program-image-wrap">
                      {grant.image
                        ? <img src={grant.image.url} alt={grant.title} class="program-image" />
                        : <div class="program-image program-image--placeholder" />}
                      {label && <span class={`status-badge status-badge--open`}>{label}</span>}
                    </div>
                    <div class="program-content"><h3>{grant.title}</h3></div>
                  </Tag>
                );
              })}
            </div>
            {openGrants.length > 3 && (
              <div class="show-more-wrap">
                <button class="show-more-btn" data-group="open-grants">もっと見る</button>
              </div>
            )}
          </div>
        ) : (
          <p class="grants-empty">現在募集中の助成プログラムはありません。</p>
        )}

        <!-- 終了 -->
        {closedGrants.length > 0 && (
          <div class="grants-closed-wrap">
            <h3 class="grants-subheading grants-subheading--closed">終了したプログラム</h3>
            <div class="grants-group" id="closed-grants">
              <div class="card-grid">
                {closedGrants.map((grant, i) => {
                  const label = statusLabel(grant);
                  const Tag = grant.url ? 'a' : 'article';
                  return (
                    <Tag
                      class={`program-card${i >= 3 ? ' grant-hidden' : ''}`}
                      {...(grant.url ? { href: grant.url, target: '_blank', rel: 'noreferrer' } : {})}
                    >
                      <div class="program-image-wrap">
                        {grant.image
                          ? <img src={grant.image.url} alt={grant.title} class="program-image" />
                          : <div class="program-image program-image--placeholder" />}
                        {label && <span class="status-badge status-badge--closed">{label}</span>}
                      </div>
                      <div class="program-content"><h3>{grant.title}</h3></div>
                    </Tag>
                  );
                })}
              </div>
              {closedGrants.length > 3 && (
                <div class="show-more-wrap">
                  <button class="show-more-btn" data-group="closed-grants">もっと見る</button>
                </div>
              )}
            </div>
          </div>
        )}
      </section>

      <section id="crowdfunding" class="section section-crowdfunding">
        <div class="section-header">
          <div>
            <h2>寄付型クラウドファンディング</h2>
            <p class="section-lead">あなたの団体の熱い想いを、共感と資金に変える仕組みです。</p>
            <p>「この地域課題を解決したい」「新しいプロジェクトを立ち上げたい」という市民活動団体の皆様の取り組みをWeb上で発信し、広く一般から寄付（活動資金）を募るプログラム（事業指定助成プログラム）です。当基金がプラットフォームを提供し、皆様の資金集めを強力にバックアップします。</p>
          </div>
        </div>

        <div class="benefit-grid">
          <article class="benefit-card">
            <div class="benefit-icon">💰</div>
            <h3>寄付者に「税制優遇」を提供できる</h3>
            <p>当基金の仕組みを活用することで、寄付者様は<strong>寄付金控除</strong>を受けることができます。これが寄付への大きな後押しとなります。</p>
          </article>

          <article class="benefit-card">
            <div class="benefit-icon">🤝</div>
            <h3>信頼性の向上</h3>
            <p>公益財団法人である当基金の審査を経てWebサイトに掲載されるため、プロジェクトの社会的な信用度が高まります。</p>
          </article>

          <article class="benefit-card">
            <div class="benefit-icon">🚀</div>
            <h3>リスクなしで挑戦できる</h3>
            <p>募集期間は最大1年間で任意に設定可能。集まった寄付金から当基金の運営費（10%）を除いた全額を活動のための助成金として交付します。</p>
          </article>
        </div>

        <div class="section-action">
          <a class="primary-button" href="/support/crowdfunding">募集要項・エントリー詳細はこちら</a>
        </div>
      </section>

      <section class="section section-support">
        <div class="section-header">
          <div>
            <h2>組織基盤強化・伴走支援</h2>
            <p class="section-lead">活動を持続可能にするため、強くてしなやかな「組織づくり」をサポートします。</p>
            <p>地域を良くする素晴らしい活動も、資金繰りや人材不足などの壁にぶつかると、長く続けることが難しくなってしまいます。当基金では「助成金をお渡しして終わり」ではなく、皆様の活動が地域に根付き、自立して継続できるよう、組織の土台づくりを伴走（並走）して支援します。</p>
          </div>
        </div>

        <div class="support-list">
          <article class="support-item">
            <div class="support-icon">✔️</div>
            <div>
              <h3>4つの視点からの総合アドバイス</h3>
              <p>団体の成長ステージに合わせて、「事業（何をするか）」「財務（お金の管理と調達）」「組織（人づくり）」「成果（社会へのインパクト）」の4つの観点から課題を整理し、解決策を一緒に考えます。</p>
            </div>
          </article>

          <article class="support-item">
            <div class="support-icon">📘</div>
            <div>
              <h3>専門的なノウハウの提供</h3>
              <p>ファンドレイジング（資金調達）の戦略、マーケティングや広報PR、非営利組織ならではの会計・税務の知識など、実践的なノウハウを提供し、組織のレベルアップを後押しします。</p>
            </div>
          </article>

          <article class="support-item">
            <div class="support-icon">🌐</div>
            <div>
              <h3>地域ネットワークとの接続</h3>
              <p>他の活動団体や企業、行政、専門家（税理士など）とのマッチングを行い、孤立させないサポート体制を築きます。</p>
            </div>
          </article>
        </div>

        <div class="section-action">
          <a class="secondary-button" href="/contact">組織の課題について相談してみる</a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-content {
    padding: var(--spacing-2xl) 0;
    max-width: 1000px;
  }

  h1 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-2xl);
    border-bottom: 3px solid var(--color-primary);
    padding-bottom: var(--spacing-lg);
  }

  .section {
    margin-bottom: var(--spacing-2xl);
    padding: var(--spacing-xl) 0;
  }

  .section-header {
    margin-bottom: var(--spacing-xl);
  }

  .section-lead {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-dark);
    margin-top: var(--spacing-sm);
  }

  .grants-subheading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 var(--spacing-lg) 0;
    padding-left: var(--spacing-md);
    border-left: 3px solid var(--color-primary);
  }

  .grants-subheading--closed {
    color: var(--color-gray);
    border-left-color: var(--color-gray);
  }

  .grants-closed-wrap {
    margin-top: var(--spacing-2xl);
  }

  .grants-empty {
    color: var(--color-gray);
    padding: var(--spacing-md) 0;
  }

  .grant-hidden {
    display: none;
  }

  .show-more-wrap {
    text-align: center;
    margin-top: var(--spacing-lg);
  }

  .show-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 2rem;
    border-radius: 999px;
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    transform: none;
    box-shadow: none;
  }

  .show-more-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: none;
    box-shadow: none;
  }

  .program-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .program-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(44, 62, 80, 0.12);
    color: inherit;
  }

  .card-grid,
  .benefit-grid,
  .support-list {
    display: grid;
    gap: var(--spacing-lg);
  }

  .card-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .program-card,
  .benefit-card,
  .support-item {
    background-color: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
  }

  .program-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .program-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .program-image--placeholder {
    background-color: rgba(94, 199, 212, 0.15);
  }

  .status-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
  }

  .status-badge--open {
    background: var(--color-primary);
    color: white;
  }

  .status-badge--closed {
    background: rgba(0, 0, 0, 0.55);
    color: white;
  }

  .status-badge--default {
    background: var(--color-accent);
    color: white;
  }

  .program-content {
    padding: var(--spacing-md) var(--spacing-lg);
  }

  .program-content h3,
  .benefit-card h3,
  .support-item h3 {
    margin-bottom: var(--spacing-sm);
    color: var(--color-dark);
  }

  .benefit-card p,
  .support-item p {
    color: var(--color-dark);
    line-height: 1.75;
    margin-bottom: var(--spacing-md);
  }

  .program-meta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .benefit-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .benefit-icon,
  .support-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: white;
    display: grid;
    place-items: center;
    font-size: 1.3rem;
    margin-bottom: var(--spacing-md);
  }

  .support-list {
    grid-template-columns: 1fr;
  }

  .support-item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: var(--spacing-md);
    align-items: flex-start;
  }

  .section-action {
    margin-top: var(--spacing-xl);
  }

  .primary-button,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.6rem;
    border-radius: 999px;
    font-weight: 700;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .primary-button {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .secondary-button {
    background-color: var(--color-accent);
    color: var(--color-dark);
  }

  .primary-button:hover,
  .secondary-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 24px rgba(94, 199, 212, 0.18);
  }

  strong {
    color: var(--color-primary);
  }

  @media (max-width: 960px) {
    .card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .benefit-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .support-item {
      grid-template-columns: 1fr;
    }

    .program-meta {
      font-size: 0.95rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.show-more-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const groupId = (btn as HTMLElement).dataset.group;
      if (!groupId) return;
      const group = document.getElementById(groupId);
      if (!group) return;
      const hidden = group.querySelectorAll('.grant-hidden');
      hidden.forEach(el => el.classList.remove('grant-hidden'));
      (btn as HTMLElement).closest('.show-more-wrap')?.remove();
    });
  });
</script>
