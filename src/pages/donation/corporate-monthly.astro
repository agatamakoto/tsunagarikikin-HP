---
// src/pages/donation/corporate-monthly.astro
// 法人向けサポーター（Pay.jp 継続課金・月額／年額）申込フォーム
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="法人サポーター お申し込み" description="えひめ西条つながり基金の法人サポーター（月額／年額）。CSR・SDGs活動として、地域課題解決に継続的に貢献いただけます。">
  <Header />

  <main>
    <div class="container form-page">
      <h1>法人サポーター お申し込み</h1>
      <p class="lead">法人・団体様として継続的にご寄付いただく制度です。月額・年額をお選びいただけます。いつでも変更・停止できます。</p>
      <p class="switch-note">個人でのお申し込みは <a href="/donation/monthly">個人用フォーム</a> をご利用ください。特典・制度の詳細は <a href="/donation/corporate">法人サポーター特設ページ</a> をご覧ください。</p>

      <form id="tmc-form" class="donation-form">
        <fieldset class="fieldset">
          <legend>ご支援のかたち・金額</legend>

          <div class="cycle-toggle">
            <label><input type="radio" name="tmc-cycle" value="month" checked><span>月額</span></label>
            <label><input type="radio" name="tmc-cycle" value="year"><span>年額</span></label>
          </div>

          <div class="amounts" id="tmc-amounts-month">
            <label><input type="radio" name="tmc-amount-month" value="3000"><span>3,000円</span></label>
            <label><input type="radio" name="tmc-amount-month" value="10000" checked><span>10,000円</span></label>
            <label><input type="radio" name="tmc-amount-month" value="30000"><span>30,000円</span></label>
            <label><input type="radio" name="tmc-amount-month" value="other"><span>その他</span></label>
          </div>

          <div class="amounts hidden" id="tmc-amounts-year">
            <label><input type="radio" name="tmc-amount-year" value="30000"><span>30,000円</span></label>
            <label><input type="radio" name="tmc-amount-year" value="50000" checked><span>50,000円</span></label>
            <label><input type="radio" name="tmc-amount-year" value="100000"><span>100,000円</span></label>
            <label><input type="radio" name="tmc-amount-year" value="other"><span>その他</span></label>
          </div>

          <div id="tmc-other-wrap" class="hidden">
            <label class="field-label" for="tmc-other">金額を入力（1,000円以上・1円単位）</label>
            <input type="number" id="tmc-other" min="1000" step="100" value="30000" placeholder="例：20,000">
          </div>
        </fieldset>

        <label class="field-label" for="tmc-company">法人名<em>必須</em></label>
        <input type="text" id="tmc-company" placeholder="株式会社西条">

        <label class="field-label" for="tmc-company-kana">法人名（フリガナ）<em>必須</em></label>
        <input type="text" id="tmc-company-kana" placeholder="カブシキガイシャサイジョウ">

        <label class="field-label" for="tmc-contact">ご担当者名<em>必須</em></label>
        <input type="text" id="tmc-contact" placeholder="西条 太郎">

        <label class="field-label" for="tmc-contact-kana">ご担当者名（フリガナ）<em>必須</em></label>
        <input type="text" id="tmc-contact-kana" placeholder="サイジョウ タロウ">

        <label class="field-label" for="tmc-dept">ご担当者 部署・役職<small>（任意）</small></label>
        <input type="text" id="tmc-dept" placeholder="総務部 部長">

        <label class="field-label" for="tmc-email">メールアドレス<em>必須</em></label>
        <input type="email" id="tmc-email" placeholder="info@example.co.jp">

        <label class="field-label" for="tmc-phone">電話番号<em>必須</em></label>
        <input type="tel" id="tmc-phone" placeholder="0897-XX-XXXX">

        <label class="field-label">所在地<small>（寄付金控除の証明書発行に使用します）</small><em>必須</em></label>
        <div class="row2">
          <input type="text" id="tmc-zip" placeholder="郵便番号 例：799-1300">
          <select id="tmc-pref"><option value="">都道府県を選択</option></select>
        </div>
        <input type="text" id="tmc-address" placeholder="市区町村・番地・建物名" class="mt8">

        <label class="field-label" for="tmc-mailing">郵送物の送付先<small>（所在地と異なる場合のみ・任意）</small></label>
        <textarea id="tmc-mailing" placeholder="所在地と異なる送付先がある場合にご記入ください"></textarea>

        <label class="field-label">広報物・お礼状等への法人名の掲載</label>
        <div class="radio-inline">
          <label><input type="radio" name="tmc-publicity" value="no" checked>掲載を希望しない</label>
          <label><input type="radio" name="tmc-publicity" value="yes">掲載を希望する</label>
        </div>

        <label class="field-label" for="tmc-referral">当基金を知ったきっかけ<small>（任意）</small></label>
        <select id="tmc-referral">
          <option value="">選択してください</option>
          <option value="homepage">ホームページ</option>
          <option value="sns">SNS</option>
          <option value="introduction">知人・関係者の紹介</option>
          <option value="event">イベント・説明会</option>
          <option value="press">新聞・報道</option>
          <option value="other">その他</option>
        </select>

        <label class="field-label">クレジットカード<em>必須</em></label>
        <div id="card-element"></div>

        <button type="submit" id="tmc-submit" class="submit-btn">この内容で申し込む</button>
        <div class="msg" id="tmc-msg"></div>
        <p class="note">お預かりしたカード情報は決済会社（Pay.jp）が直接処理し、当基金のサーバーには保存されません。請求書払いをご希望の場合は <a href="/contact">お問い合わせ</a> ください。</p>
      </form>
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline src="https://js.pay.jp/v2/pay.js"></script>
<script>
  import { PAYJP_PUBLIC_KEY, DONATION_API_URL } from '../../lib/donationConfig';

  const PREFECTURES = ["北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県","茨城県","栃木県","群馬県",
    "埼玉県","千葉県","東京都","神奈川県","新潟県","富山県","石川県","福井県","山梨県","長野県",
    "岐阜県","静岡県","愛知県","三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県",
    "鳥取県","島根県","岡山県","広島県","山口県","徳島県","香川県","愛媛県","高知県","福岡県",
    "佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"];
  const prefSelect = document.getElementById("tmc-pref");
  PREFECTURES.forEach((p) => { const o = document.createElement("option"); o.value = p; o.textContent = p; prefSelect.appendChild(o); });

  const payjp = window.Payjp(PAYJP_PUBLIC_KEY);
  const elements = payjp.elements();
  const card = elements.create("card");
  card.mount("#card-element");

  const form = document.getElementById("tmc-form");
  const msg = document.getElementById("tmc-msg");
  const submit = document.getElementById("tmc-submit");
  const otherWrap = document.getElementById("tmc-other-wrap");
  const amountsMonth = document.getElementById("tmc-amounts-month");
  const amountsYear = document.getElementById("tmc-amounts-year");

  function getCycle() { return form.querySelector('input[name="tmc-cycle"]:checked').value; }
  function getSelectedAmountRaw() {
    const el = form.querySelector('input[name="tmc-amount-' + getCycle() + '"]:checked');
    return el ? el.value : null;
  }
  function getAmount() {
    const v = getSelectedAmountRaw();
    if (v === "other") return parseInt(document.getElementById("tmc-other").value, 10);
    return parseInt(v, 10);
  }
  function updateOther() { otherWrap.classList.toggle("hidden", getSelectedAmountRaw() !== "other"); }
  function show(type, text) { msg.className = "msg " + type; msg.textContent = text; }

  form.querySelectorAll('input[name="tmc-cycle"]').forEach((r) => {
    r.addEventListener("change", () => {
      const cycle = getCycle();
      amountsMonth.classList.toggle("hidden", cycle !== "month");
      amountsYear.classList.toggle("hidden", cycle !== "year");
      updateOther();
    });
  });
  form.querySelectorAll('input[name="tmc-amount-month"], input[name="tmc-amount-year"]').forEach((r) => {
    r.addEventListener("change", updateOther);
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    show("", "");

    const cycle = getCycle();
    const amount = getAmount();
    if (!Number.isInteger(amount) || amount < 1000) { show("err", "金額は1,000円以上で指定してください。"); return; }

    const payload = {
      entityType: "corporate",
      billingCycle: cycle,
      amount,
      companyName: document.getElementById("tmc-company").value.trim(),
      companyKana: document.getElementById("tmc-company-kana").value.trim(),
      contactName: document.getElementById("tmc-contact").value.trim(),
      contactKana: document.getElementById("tmc-contact-kana").value.trim(),
      department: document.getElementById("tmc-dept").value.trim(),
      email: document.getElementById("tmc-email").value.trim(),
      phone: document.getElementById("tmc-phone").value.trim(),
      zip: document.getElementById("tmc-zip").value.trim(),
      prefecture: document.getElementById("tmc-pref").value,
      address: document.getElementById("tmc-address").value.trim(),
      mailingAddress: document.getElementById("tmc-mailing").value.trim(),
      publicity: (form.querySelector('input[name="tmc-publicity"]:checked') || {}).value || "no",
      referral: document.getElementById("tmc-referral").value,
    };

    if (!payload.companyName || !payload.companyKana) { show("err", "法人名・フリガナを入力してください。"); return; }
    if (!payload.contactName || !payload.contactKana) { show("err", "ご担当者名・フリガナを入力してください。"); return; }
    if (!payload.email) { show("err", "メールアドレスを入力してください。"); return; }
    if (!payload.phone) { show("err", "電話番号を入力してください。"); return; }
    if (!payload.zip || !payload.prefecture || !payload.address) { show("err", "所在地を入力してください（寄付金控除の証明書発行に必要です）。"); return; }

    submit.disabled = true; submit.textContent = "処理中…";
    try {
      const t = await payjp.createToken(card);
      if (t.error) { show("err", "カード情報を確認してください：" + t.error.message); return; }
      payload.token = t.id;

      const res = await fetch(DONATION_API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) { show("err", "申し込みに失敗しました：" + (data.error || "しばらくして再度お試しください")); return; }

      const label = cycle === "year" ? ("年額" + amount.toLocaleString() + "円") : ("毎月" + amount.toLocaleString() + "円");
      form.style.display = "none";
      show("ok", "ありがとうございます。" + label + "のご寄付を承りました。確認メールをお送りします。");
    } catch (err) {
      show("err", "通信エラーが発生しました。時間をおいて再度お試しください。");
    } finally {
      submit.disabled = false; submit.textContent = "この内容で申し込む";
    }
  });
</script>

<style>
  .form-page {
    max-width: 640px;
    padding: var(--spacing-2xl) var(--spacing-md);
  }
  .form-page h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-dark);
    border-bottom: 3px solid var(--color-primary);
    padding-bottom: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }
  .lead { font-size: 1.05rem; font-weight: 600; color: var(--color-dark); }
  .switch-note { font-size: 0.9rem; color: var(--color-gray); }

  .donation-form { margin-top: var(--spacing-lg); }
  .field-label { display: block; font-size: 0.9rem; font-weight: 700; margin: var(--spacing-lg) 0 var(--spacing-xs); color: var(--color-dark); }
  .field-label small { font-weight: 400; color: var(--color-gray); font-size: 0.8rem; margin-left: 4px; }
  .field-label em { font-style: normal; font-size: 0.7rem; background: var(--color-accent); color: #fff; border-radius: 4px; padding: 1px 6px; margin-left: 6px; vertical-align: middle; }

  .donation-form input[type=text],
  .donation-form input[type=email],
  .donation-form input[type=tel],
  .donation-form input[type=number],
  .donation-form select,
  .donation-form textarea {
    width: 100%;
    box-sizing: border-box;
    padding: 12px;
    border: 1px solid #d5dde0;
    border-radius: 12px;
    font-size: 1rem;
    font-family: var(--font-family);
    background: var(--color-white);
  }
  .donation-form textarea { resize: vertical; min-height: 62px; }
  .mt8 { margin-top: var(--spacing-sm); }
  .row2 { display: flex; gap: 10px; }
  .row2 > * { flex: 1; }

  .fieldset { border: 1px solid #e2e8ea; border-radius: 16px; padding: var(--spacing-md) var(--spacing-lg); margin: var(--spacing-lg) 0 0; }
  .fieldset legend { font-size: 0.9rem; font-weight: 700; padding: 0 6px; color: var(--color-dark); }

  .cycle-toggle { display: flex; gap: 8px; margin-bottom: var(--spacing-md); }
  .cycle-toggle label { flex: 1; text-align: center; border: 2px solid #d5dde0; border-radius: 12px; padding: 10px 6px; cursor: pointer; font-weight: 700; position: relative; }
  .cycle-toggle input { position: absolute; opacity: 0; }
  .cycle-toggle label:has(input:checked) { border-color: var(--color-accent); background: rgba(255,159,60,0.12); color: #e07f1e; }

  .amounts { display: flex; gap: 8px; flex-wrap: wrap; }
  .amounts label { flex: 1; min-width: 88px; text-align: center; border: 2px solid #d5dde0; border-radius: 12px; padding: 12px 6px; cursor: pointer; font-weight: 700; position: relative; }
  .amounts input { position: absolute; opacity: 0; }
  .amounts label:has(input:checked) { border-color: var(--color-primary); background: rgba(94,199,212,0.12); color: #2a8aaa; }

  .radio-inline { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 6px; }
  .radio-inline label { display: flex; align-items: center; gap: 6px; font-size: 0.9rem; cursor: pointer; }

  #card-element { padding: 12px; border: 1px solid #d5dde0; border-radius: 12px; background: var(--color-white); }
  .hidden { display: none; }

  .submit-btn {
    width: 100%; margin-top: var(--spacing-xl); padding: 15px; border-radius: 999px;
    background: var(--color-primary); color: #fff; font-size: 1.05rem; font-weight: 700;
  }
  .submit-btn:hover { background: #4baab3; }
  .submit-btn:disabled { background: var(--color-gray); box-shadow: none; transform: none; }

  .msg { margin-top: var(--spacing-md); padding: 12px; border-radius: 10px; font-size: 0.9rem; display: none; }
  .msg.err { display: block; background: #fdecea; color: #b3261e; }
  .msg.ok { display: block; background: #e6f4ea; color: #1e7d34; }
  .note { font-size: 0.78rem; color: var(--color-gray); margin-top: 10px; }
</style>
