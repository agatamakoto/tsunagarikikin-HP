---
// src/pages/donation/onetime.astro
// 個人向け 都度寄付（単発・Pay.jp 1回課金）フォーム
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="都度寄付（今回のみのご寄付）" description="えひめ西条つながり基金への今回のみのご寄付。任意の金額をクレジットカードでご寄付いただけます。">
  <Header />

  <main>
    <div class="container form-page">
      <h1>都度寄付（今回のみ）</h1>
      <p class="lead">「今、応援したい」というタイミングで、任意の金額を一度だけご寄付いただけます。継続の課金は発生しません。</p>
      <p class="switch-note">毎月続けてのご支援は <a href="/donation/monthly">マンスリーサポーター</a> をご利用ください。</p>

      <form id="to-form" class="donation-form">
        <fieldset class="fieldset">
          <legend>ご寄付の金額</legend>
          <div class="quick-amounts">
            <button type="button" class="quick" data-amt="1000">1,000円</button>
            <button type="button" class="quick" data-amt="3000">3,000円</button>
            <button type="button" class="quick" data-amt="5000">5,000円</button>
            <button type="button" class="quick" data-amt="10000">10,000円</button>
          </div>
          <label class="field-label" for="to-amount">金額（1,000円以上・1円単位）</label>
          <div class="amount-input">
            <span class="yen">¥</span>
            <input type="number" id="to-amount" min="1000" step="100" value="3000">
          </div>
        </fieldset>

        <fieldset class="fieldset">
          <legend>寄付の使いみち</legend>
          <label class="radio-line"><input type="radio" name="to-purpose" value="財団運営" checked>
            <span>指定なし<small>（財団運営として自由にご活用ください）</small></span></label>
          <label class="radio-line"><input type="radio" name="to-purpose" value="障害者支援">
            <span>障害者支援</span></label>
          <label class="radio-line"><input type="radio" name="to-purpose" value="防災">
            <span>防災</span></label>
          <label class="radio-line"><input type="radio" name="to-purpose" value="other">
            <span>その他（具体的にご記入ください）</span></label>
          <div id="to-purpose-other-wrap" class="hidden">
            <input type="text" id="to-purpose-other" placeholder="例：〇〇プロジェクトへのご寄付など" class="mt8">
          </div>
        </fieldset>

        <fieldset class="fieldset">
          <legend>寄付の方法</legend>
          <label class="radio-line"><input type="radio" name="to-mode" value="named" checked>
            <span>お名前を登録して寄付する<small>（寄付金控除の領収書発行に対応します）</small></span></label>
          <label class="radio-line"><input type="radio" name="to-mode" value="anonymous">
            <span>匿名で寄付する<small>（お名前・ご住所は伺いません。領収書は発行されません）</small></span></label>
          <div class="anon-note" id="to-anon-note">匿名を選択されました。ご寄付の受付・確認連絡のためメールアドレスのみお伺いします。氏名・ご住所は登録されません。</div>
        </fieldset>

        <div id="to-identity">
          <label class="field-label" for="to-name">お名前<em>必須</em></label>
          <input type="text" id="to-name" placeholder="西条 太郎">

          <label class="field-label" for="to-kana">フリガナ<em>必須</em></label>
          <input type="text" id="to-kana" placeholder="サイジョウ タロウ">

          <label class="field-label">性別<small>（任意）</small></label>
          <div class="radio-inline">
            <label><input type="radio" name="to-gender" value="" checked>未回答</label>
            <label><input type="radio" name="to-gender" value="male">男性</label>
            <label><input type="radio" name="to-gender" value="female">女性</label>
            <label><input type="radio" name="to-gender" value="other">その他</label>
          </div>

          <label class="field-label" for="to-birthdate">生年月日<small>（任意）</small></label>
          <input type="date" id="to-birthdate">

          <label class="field-label" for="to-phone">電話番号<em>必須</em></label>
          <input type="tel" id="to-phone" placeholder="090-1234-5678">

          <label class="field-label">ご住所<small>（寄付金控除の証明書発行に使用します）</small><em>必須</em></label>
          <div class="row2">
            <input type="text" id="to-zip" placeholder="郵便番号 例：799-1300">
            <select id="to-pref"><option value="">都道府県を選択</option></select>
          </div>
          <input type="text" id="to-address" placeholder="市区町村・番地・建物名" class="mt8">

          <label class="field-label" for="to-mailing">郵送物の送付先<small>（上記と異なる場合のみ・任意）</small></label>
          <textarea id="to-mailing" placeholder="ご住所と異なる送付先がある場合にご記入ください"></textarea>

          <label class="field-label">広報物・お礼状等へのお名前の掲載</label>
          <div class="radio-inline">
            <label><input type="radio" name="to-publicity" value="no" checked>掲載を希望しない</label>
            <label><input type="radio" name="to-publicity" value="yes">掲載を希望する</label>
          </div>
        </div>

        <label class="field-label" for="to-email">メールアドレス<em>必須</em></label>
        <input type="email" id="to-email" placeholder="taro@example.com">

        <label class="field-label" for="to-referral">当基金を知ったきっかけ<small>（任意）</small></label>
        <select id="to-referral">
          <option value="">選択してください</option>
          <option value="homepage">ホームページ</option>
          <option value="sns">SNS</option>
          <option value="introduction">知人・関係者の紹介</option>
          <option value="event">イベント・説明会</option>
          <option value="press">新聞・報道</option>
          <option value="other">その他</option>
        </select>

        <label class="field-label">クレジットカード<em>必須</em></label>
        <div id="card-element"></div>

        <button type="submit" id="to-submit" class="submit-btn">この内容で寄付する</button>
        <div class="msg" id="to-msg"></div>
        <p class="note">お預かりしたカード情報は決済会社（Pay.jp）が直接処理し、当基金のサーバーには保存されません。銀行振込をご希望の場合は <a href="/contact">お問い合わせ</a> ください。</p>
      </form>
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline src="https://js.pay.jp/v2/pay.js"></script>
<script>
  import { PAYJP_PUBLIC_KEY, DONATION_API_URL } from '../../lib/donationConfig';

  const PREFECTURES = ["北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県","茨城県","栃木県","群馬県",
    "埼玉県","千葉県","東京都","神奈川県","新潟県","富山県","石川県","福井県","山梨県","長野県",
    "岐阜県","静岡県","愛知県","三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県",
    "鳥取県","島根県","岡山県","広島県","山口県","徳島県","香川県","愛媛県","高知県","福岡県",
    "佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"];
  const prefSelect = document.getElementById("to-pref");
  PREFECTURES.forEach((p) => { const o = document.createElement("option"); o.value = p; o.textContent = p; prefSelect.appendChild(o); });

  const payjp = window.Payjp(PAYJP_PUBLIC_KEY);
  const elements = payjp.elements();
  const card = elements.create("card");
  card.mount("#card-element");

  const form = document.getElementById("to-form");
  const msg = document.getElementById("to-msg");
  const submit = document.getElementById("to-submit");
  const amountInput = document.getElementById("to-amount");
  const identity = document.getElementById("to-identity");
  const anonNote = document.getElementById("to-anon-note");

  form.querySelectorAll(".quick").forEach((b) => {
    b.addEventListener("click", () => { amountInput.value = b.dataset.amt; });
  });

  form.querySelectorAll('input[name="to-mode"]').forEach((r) => {
    r.addEventListener("change", () => {
      const anon = getMode() === "anonymous";
      identity.classList.toggle("hidden", anon);
      anonNote.classList.toggle("show", anon);
    });
  });

  const purposeOtherWrap = document.getElementById("to-purpose-other-wrap");
  form.querySelectorAll('input[name="to-purpose"]').forEach((r) => {
    r.addEventListener("change", () => {
      purposeOtherWrap.classList.toggle("hidden", getPurposeRaw() !== "other");
    });
  });

  function getMode() { return form.querySelector('input[name="to-mode"]:checked').value; }
  function getPurposeRaw() {
    const el = form.querySelector('input[name="to-purpose"]:checked');
    return el ? el.value : "財団運営";
  }
  function getPurpose() {
    const v = getPurposeRaw();
    if (v === "other") return document.getElementById("to-purpose-other").value.trim() || "その他";
    return v;
  }
  function show(type, text) { msg.className = "msg " + type; msg.textContent = text; }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    show("", "");

    const amount = parseInt(amountInput.value, 10);
    if (!Number.isInteger(amount) || amount < 1000) { show("err", "金額は1,000円以上で指定してください。"); return; }

    const anonymous = getMode() === "anonymous";
    const email = document.getElementById("to-email").value.trim();
    if (!email) { show("err", "メールアドレスを入力してください。"); return; }

    const payload = {
      entityType: "individual",
      donationType: "onetime",
      anonymous,
      amount,
      email,
      purpose: getPurpose(),
      referral: document.getElementById("to-referral").value,
    };

    if (!anonymous) {
      payload.name = document.getElementById("to-name").value.trim();
      payload.kana = document.getElementById("to-kana").value.trim();
      payload.gender = (form.querySelector('input[name="to-gender"]:checked') || {}).value || "";
      payload.birthdate = document.getElementById("to-birthdate").value;
      payload.phone = document.getElementById("to-phone").value.trim();
      payload.zip = document.getElementById("to-zip").value.trim();
      payload.prefecture = document.getElementById("to-pref").value;
      payload.address = document.getElementById("to-address").value.trim();
      payload.mailingAddress = document.getElementById("to-mailing").value.trim();
      payload.publicity = (form.querySelector('input[name="to-publicity"]:checked') || {}).value || "no";

      if (!payload.name || !payload.kana) { show("err", "お名前・フリガナを入力してください。"); return; }
      if (!payload.phone) { show("err", "電話番号を入力してください。"); return; }
      if (!payload.zip || !payload.prefecture || !payload.address) { show("err", "ご住所を入力してください（寄付金控除の証明書発行に必要です）。"); return; }
    }

    submit.disabled = true; submit.textContent = "処理中…";
    try {
      const t = await payjp.createToken(card);
      if (t.error) { show("err", "カード情報を確認してください：" + t.error.message); return; }
      payload.token = t.id;

      const res = await fetch(DONATION_API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) { show("err", "寄付に失敗しました：" + (data.error || "しばらくして再度お試しください")); return; }

      window.location.href = "/donation/thanks?type=onetime&amount=" + amount;
    } catch (err) {
      show("err", "通信エラーが発生しました。時間をおいて再度お試しください。");
    } finally {
      submit.disabled = false; submit.textContent = "この内容で寄付する";
    }
  });
</script>

<style>
  .form-page {
    max-width: 640px;
    padding: var(--spacing-2xl) var(--spacing-md);
  }
  .form-page h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-dark);
    border-bottom: 3px solid var(--color-primary);
    padding-bottom: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }
  .lead { font-size: 1.05rem; font-weight: 600; color: var(--color-dark); }
  .switch-note { font-size: 0.9rem; color: var(--color-gray); }

  .donation-form { margin-top: var(--spacing-lg); }
  .field-label { display: block; font-size: 0.9rem; font-weight: 700; margin: var(--spacing-lg) 0 var(--spacing-xs); color: var(--color-dark); }
  .field-label small { font-weight: 400; color: var(--color-gray); font-size: 0.8rem; margin-left: 4px; }
  .field-label em { font-style: normal; font-size: 0.7rem; background: var(--color-accent); color: #fff; border-radius: 4px; padding: 1px 6px; margin-left: 6px; vertical-align: middle; }

  .donation-form input[type=text],
  .donation-form input[type=email],
  .donation-form input[type=tel],
  .donation-form input[type=number],
  .donation-form input[type=date],
  .donation-form select,
  .donation-form textarea {
    width: 100%;
    box-sizing: border-box;
    padding: 12px;
    border: 1px solid #d5dde0;
    border-radius: 12px;
    font-size: 1rem;
    font-family: var(--font-family);
    background: var(--color-white);
  }
  .donation-form textarea { resize: vertical; min-height: 62px; }
  .mt8 { margin-top: var(--spacing-sm); }
  .row2 { display: flex; gap: 10px; }
  .row2 > * { flex: 1; }

  .fieldset { border: 1px solid #e2e8ea; border-radius: 16px; padding: var(--spacing-md) var(--spacing-lg); margin: var(--spacing-lg) 0 0; }
  .fieldset legend { font-size: 0.9rem; font-weight: 700; padding: 0 6px; color: var(--color-dark); }

  .quick-amounts { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: var(--spacing-sm); }
  .quick { flex: 1; min-width: 84px; border: 2px solid #d5dde0; border-radius: 12px; padding: 10px 6px; background: var(--color-white); font-weight: 700; color: var(--color-dark); }
  .quick:hover { border-color: var(--color-primary); background: rgba(94,199,212,0.10); color: #2a8aaa; box-shadow: none; transform: none; }

  .amount-input { display: flex; align-items: center; gap: 8px; }
  .amount-input .yen { font-size: 1.3rem; font-weight: 700; color: var(--color-dark); }
  .amount-input input { font-size: 1.2rem; font-weight: 700; }

  .radio-line { display: flex; align-items: flex-start; gap: 8px; margin: 10px 0; cursor: pointer; font-size: 0.95rem; }
  .radio-line input { margin-top: 4px; }
  .radio-line small { display: block; color: var(--color-gray); font-size: 0.78rem; }
  .radio-inline { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 6px; }
  .radio-inline label { display: flex; align-items: center; gap: 6px; font-size: 0.9rem; cursor: pointer; }

  #card-element { padding: 12px; border: 1px solid #d5dde0; border-radius: 12px; background: var(--color-white); }

  .anon-note { display: none; font-size: 0.82rem; color: #2a8aaa; background: rgba(94,199,212,0.12); border-radius: 10px; padding: 10px; margin-top: 8px; }
  .anon-note.show { display: block; }
  .hidden { display: none; }

  .submit-btn {
    width: 100%; margin-top: var(--spacing-xl); padding: 15px; border-radius: 999px;
    background: var(--color-primary); color: #fff; font-size: 1.05rem; font-weight: 700;
  }
  .submit-btn:hover { background: #4baab3; }
  .submit-btn:disabled { background: var(--color-gray); box-shadow: none; transform: none; }

  .msg { margin-top: var(--spacing-md); padding: 12px; border-radius: 10px; font-size: 0.9rem; display: none; }
  .msg.err { display: block; background: #fdecea; color: #b3261e; }
  .msg.ok { display: block; background: #e6f4ea; color: #1e7d34; }
  .note { font-size: 0.78rem; color: var(--color-gray); margin-top: 10px; }
</style>
