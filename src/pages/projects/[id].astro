---
// src/pages/projects/[id].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { client } from '../../lib/microcms';
import type { Project } from '../../lib/microcms';

export async function getStaticPaths() {
  try {
    const projectsData = await client.get({ endpoint: 'projects', queries: { limit: 100 } });
    return projectsData.contents.map((project: Project) => ({
      params: { id: project.id },
      props: { project },
    }));
  } catch (e) {
    return [];
  }
}

const { project } = Astro.props as { project: Project };
---

<Layout title={project.title} description={project.description}>
  <Header />

  <main>
    <div class="container page">
      <nav class="breadcrumb">
        <a href="/projects">← プロジェクト一覧に戻る</a>
      </nav>

      <article class="project-article">
        <header class="article-header">
          <span class="project-tag">進行中</span>
          <h1>{project.title}</h1>
          <p class="article-lead">{project.description}</p>
        </header>

        {project.image && (
          <div class="article-image-wrap">
            <img src={project.image.url} alt={project.title} class="article-image" />
          </div>
        )}

        {project.content && (
          <div class="article-body" set:html={project.content} />
        )}
      </article>

      <div class="cta-wrap">
        <p>このプロジェクトへの参加・連携についてはお問い合わせください。</p>
        <a href="/contact" class="cta-button">お問い合わせ・連携のご相談</a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page {
    padding: var(--spacing-2xl) 0;
    max-width: 860px;
  }

  .breadcrumb {
    margin-bottom: var(--spacing-xl);
  }

  .breadcrumb a {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .project-article {
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(44, 62, 80, 0.05);
    margin-bottom: var(--spacing-2xl);
  }

  .article-header {
    padding: var(--spacing-2xl);
    padding-bottom: var(--spacing-lg);
  }

  .project-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    background: rgba(94, 199, 212, 0.18);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: var(--spacing-md);
  }

  .article-header h1 {
    color: var(--color-dark);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.3;
    margin: var(--spacing-sm) 0 var(--spacing-md);
  }

  .article-lead {
    color: var(--color-gray);
    font-size: 1.05rem;
    line-height: 1.75;
    margin: 0;
  }

  .article-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .article-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-body {
    padding: var(--spacing-2xl);
    line-height: 1.9;
    color: var(--color-dark);
  }

  .article-body :global(p) {
    margin-bottom: var(--spacing-md);
  }

  .article-body :global(h2),
  .article-body :global(h3) {
    color: var(--color-primary);
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }

  .article-body :global(img) {
    border-radius: 12px;
    margin: var(--spacing-lg) 0;
    width: 100%;
  }

  .article-body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .cta-wrap {
    text-align: center;
    padding: var(--spacing-xl);
    background: linear-gradient(135deg, rgba(94, 199, 212, 0.1), rgba(255, 159, 60, 0.08));
    border-radius: 24px;
    border: 1px solid rgba(94, 199, 212, 0.2);
  }

  .cta-wrap p {
    color: var(--color-dark);
    margin-bottom: var(--spacing-lg);
    font-size: 1.05rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.8rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-dark);
    font-weight: 700;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(255, 159, 60, 0.25);
    color: var(--color-dark);
  }

  @media (max-width: 700px) {
    .page {
      padding: var(--spacing-xl) 0;
    }

    .article-header {
      padding: var(--spacing-lg);
    }

    .article-body {
      padding: var(--spacing-lg);
    }
  }
</style>
