---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import QuestionFlow from '../components/QuestionFlow.astro';
import Footer from '../components/Footer.astro';
import { client } from '../lib/microcms';
import type { News, Statistic, Project, Report } from '../lib/microcms';

let newsList: News[] = [];
let stats: Statistic | null = null;
let projectsList: Project[] = [];
let latestReport: Report | null = null;

try {
  const newsData = await client.get({ endpoint: 'news', queries: { limit: 3 } });
  newsList = newsData.contents;
} catch (e) {}

try {
  stats = await client.get({ endpoint: 'statistics' });
} catch (e) {}

try {
  const projectsData = await client.get({ endpoint: 'projects', queries: { limit: 3 } });
  projectsList = projectsData.contents;
} catch (e) {}

try {
  const reportsData = await client.get({ endpoint: 'reports', queries: { limit: 1 } });
  latestReport = reportsData.contents[0] ?? null;
} catch (e) {}
---

<Layout title="トップページ" description="西条の地から、地域共創のプラットフォームへ">
  <Header />

  <main>
    <!-- メインビジュアル (Hero Section) -->
    <section class="hero">
      <div class="hero-content">
        <p class="eyebrow">西条の地から、地域共創のプラットフォームへ</p>
        <h1>公益財団法人<br>えひめ西条つながり基金</h1>
        <p class="hero-copy">つながりを豊かにして持続可能な地域を創る</p>
        <div class="hero-actions">
          <a href="#question-flow" class="hero-button">参加する</a>
          <a href="/about" class="hero-link">詳しく知る</a>
        </div>
      </div>
    </section>

    <!-- 質問フロー -->
    <div id="question-flow">
      <QuestionFlow />
    </div>

    <!-- 現在進行中のプロジェクト -->
    <section class="projects-section">
      <div class="container">
        <h2>現在進行中のプロジェクト</h2>
        <div class="projects-grid">
          {projectsList.length > 0 ? (
            projectsList.map((project) => (
              <a href={`/projects/${project.id}`} class="project-card">
                <div class="project-image">
                  {project.image && <img src={project.image.url} alt={project.title} />}
                </div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <span class="link-arrow">詳しく見る →</span>
              </a>
            ))
          ) : (
            <p class="empty-message">プロジェクトを準備中です。</p>
          )}
        </div>

        <div class="view-all">
          <a href="/projects" class="view-all-button">プロジェクト一覧を見る</a>
        </div>
      </div>
    </section>

    <!-- 活動を知る -->
    <section class="news-section">
      <div class="container">
        <h2>活動を知る</h2>
        <div class="news-grid">
          <!-- お知らせ -->
          <div class="news-subsection">
            <h3>お知らせ</h3>
            {newsList.length > 0 ? (
              <ul class="news-list">
                {newsList.map((news) => (
                  <li>
                    <a href="/activities#news">
                      <span class="news-date">{news.publishedAt.slice(0, 10).replace(/-/g, '.')}</span>
                      {news.title}
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="empty-message">お知らせを準備中です。</p>
            )}
            {newsList.length > 0 && (
              <a href="/activities#news" class="more-link">もっと見る →</a>
            )}
          </div>

          <!-- 統計情報 -->
          <div class="stats-section">
            <h3>えひめ西条つながり基金の実績</h3>
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-number">
                  {stats ? Math.floor(stats.total_amount / 10000).toLocaleString() + '万円' : '集計中'}
                </div>
                <div class="stat-label">寄付総額</div>
              </div>
              <div class="stat-card">
                <div class="stat-number">
                  {stats ? stats.supporter_count.toLocaleString() + '人' : '集計中'}
                </div>
                <div class="stat-label">寄付者延べ人数</div>
              </div>
            </div>
          </div>

          <!-- 助成先の声・活動レポート -->
          <div class="news-subsection">
            <h3>助成先の声・活動レポート</h3>
            {latestReport ? (
              <div class="report-preview">
                {latestReport.image && (
                  <img src={latestReport.image.url} alt="活動の様子" class="report-preview-img" />
                )}
                <p class="report-org">{latestReport.organization}</p>
                <p class="report-title-text">
                  <a href="/activities">{latestReport.title}</a>
                </p>
                <p class="report-summary">{latestReport.summary}</p>
                <a href="/activities" class="link-arrow">レポート一覧を見る →</a>
              </div>
            ) : (
              <p class="empty-message">レポートを準備中です。</p>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- これからの財団について -->
    <section class="future-section">
      <div class="container">
        <div class="future-content">
          <h2>これからの財団について</h2>
          <p>公益財団法人えひめ西条つながり基金は、オープンソース化を推し進めます。私たちの試行錯誤や知見を積極的に共有し、全国の地域共創の取り組みに貢献していきます。</p>
          <a href="/about#opensource" class="learn-more-button">詳しく知る</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    min-height: calc(100vh - 60px);
  }

  /* Hero Section */
  .hero {
    background: linear-gradient(180deg, #E0F4FF 0%, #B8E8F7 42%, #ffffff 100%);
    color: var(--color-dark);
    padding: 100px 0 120px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .eyebrow {
    display: inline-block;
    background: rgba(94, 199, 212, 0.15);
    color: var(--color-primary);
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.95rem;
    margin-bottom: var(--spacing-md);
  }

  .hero h1 {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    margin-bottom: var(--spacing-md);
    margin-top: 0;
    line-height: 1.03;
  }

  .hero-copy {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.8;
    color: var(--color-dark);
    margin-bottom: var(--spacing-xl);
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-button,
  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 1rem 1.8rem;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .hero-button {
    background-color: var(--color-accent);
    color: white;
    box-shadow: 0 18px 40px rgba(59, 155, 200, 0.24);
  }

  .hero-button:hover {
    transform: translateY(-3px);
    background-color: #e8891e;
    color: white;
  }

  .hero-link {
    color: var(--color-dark);
    border: 1px solid rgba(16, 43, 70, 0.12);
    background: rgba(255, 255, 255, 0.92);
  }

  /* Projects Section */
  .projects-section {
    padding: var(--spacing-2xl) 0;
  }

  .projects-section h2 {
    text-align: center;
    color: var(--color-primary);
    margin-bottom: var(--spacing-2xl);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-2xl);
  }

  .project-card {
    display: block;
    color: inherit;
    text-decoration: none;
    background-color: var(--color-white);
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .project-card:hover {
    box-shadow: 0 8px 24px rgba(94, 199, 212, 0.15);
    transform: translateY(-4px);
    color: inherit;
  }

  .project-image {
    width: 100%;
    height: 200px;
    background-color: rgba(94, 199, 212, 0.15);
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-card h3 {
    padding: var(--spacing-md) var(--spacing-md) 0;
    margin-bottom: var(--spacing-sm);
    margin-top: var(--spacing-md);
  }

  .project-card p {
    padding: 0 var(--spacing-md);
    margin-bottom: var(--spacing-md);
    color: var(--color-gray);
  }

  .link-arrow {
    display: block;
    padding: 0 var(--spacing-md) var(--spacing-md);
    color: var(--color-primary);
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .link-arrow:hover {
    color: var(--color-accent);
  }

  .view-all {
    text-align: center;
  }

  .view-all-button {
    display: inline-block;
    background-color: var(--color-primary);
    color: white;
    padding: var(--spacing-md) var(--spacing-xl);
    border-radius: 30px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .view-all-button:hover {
    background-color: #4baab3;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(94, 199, 212, 0.3);
    color: white;
  }

  /* News Section */
  .news-section {
    padding: var(--spacing-2xl) 0;
    background-color: var(--color-light);
  }

  .news-section h2 {
    text-align: center;
    color: var(--color-primary);
    margin-bottom: var(--spacing-2xl);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-xl);
  }

  .news-subsection h3,
  .stats-section h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
    margin-top: 0;
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--color-primary);
  }

  .news-list {
    list-style: none;
  }

  .news-list li {
    margin-bottom: var(--spacing-md);
  }

  .news-list a {
    color: var(--color-dark);
    transition: color 0.3s ease;
    text-decoration: none;
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
  }

  .news-list a::before {
    content: '→';
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .news-list a:hover {
    color: var(--color-primary);
  }

  .news-date {
    color: var(--color-gray);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .more-link {
    display: inline-block;
    margin-top: var(--spacing-md);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .more-link:hover {
    color: var(--color-accent);
  }

  /* Stats Section */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--spacing-lg);
  }

  .stat-card {
    background-color: var(--color-white);
    border: 2px solid var(--color-primary);
    border-radius: 12px;
    padding: var(--spacing-lg);
    text-align: center;
  }

  .stat-number {
    font-size: var(--font-size-3xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  .stat-label {
    color: var(--color-gray);
    font-size: var(--font-size-base);
  }

  /* Report Preview */
  .report-preview {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .report-preview-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: var(--spacing-sm);
  }

  .report-org {
    color: var(--color-gray);
    font-size: 0.9rem;
    margin: 0;
  }

  .report-title-text {
    font-weight: 700;
    margin: 0;
    line-height: 1.5;
  }

  .report-title-text a {
    color: var(--color-dark);
  }

  .report-title-text a:hover {
    color: var(--color-primary);
  }

  .report-summary {
    color: var(--color-gray);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .report-preview .link-arrow {
    padding: 0;
    margin-top: var(--spacing-sm);
  }

  .empty-message {
    color: var(--color-gray);
  }

  /* Future Section */
  .future-section {
    padding: var(--spacing-2xl) 0;
    background: linear-gradient(135deg, rgba(94, 199, 212, 0.1) 0%, rgba(255, 159, 60, 0.1) 100%);
  }

  .future-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .future-content h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .future-content p {
    font-size: var(--font-size-lg);
    color: var(--color-dark);
    margin-bottom: var(--spacing-xl);
    line-height: 1.8;
  }

  .learn-more-button {
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    padding: var(--spacing-md) var(--spacing-xl);
    border-radius: 30px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .learn-more-button:hover {
    background-color: #e8891e;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 159, 60, 0.3);
    color: white;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 60px var(--spacing-md);
    }

    .hero h1 {
      font-size: var(--font-size-3xl);
    }

    .projects-grid,
    .news-grid {
      grid-template-columns: 1fr;
    }

    .news-section {
      padding: var(--spacing-xl) 0;
    }

    .stat-number {
      font-size: var(--font-size-2xl);
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .news-subsection h3,
    .stats-section h3 {
      font-size: var(--font-size-xl);
    }
  }
</style>
