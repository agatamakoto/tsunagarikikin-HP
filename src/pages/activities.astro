---
// src/pages/activities.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { client } from '../lib/microcms';
import type { News, Statistic, Report } from '../lib/microcms';

let newsList: News[] = [];
let stats: Statistic | null = null;
let reportsList: Report[] = [];

try {
  const response = await client.get({ endpoint: 'news' });
  newsList = response.contents;
} catch (e) {}

try {
  stats = await client.get({ endpoint: 'statistics' });
} catch (e) {}

try {
  const reportsData = await client.get({ endpoint: 'reports', queries: { limit: 6 } });
  reportsList = reportsData.contents;
} catch (e) {}
---

<Layout title="活動を知る" description="寄付の活用や活動報告をご紹介します">
  <Header />

  <main>
    <div class="container page">
      <header class="page-header">
        <h1>活動を知る</h1>
        <p class="intro">皆様からお預かりした大切なご寄付が、どのように愛媛の地域課題解決に活かされているか、最新の取り組みや成果をご報告します。</p>
      </header>

      <section class="section impact">
        <div class="section-head">
          <h2>これまでのご支援</h2>
        </div>

        <div class="stat-grid">
          <article class="stat-card">
            <p class="stat-label">寄付総額</p>
            <p class="stat-value">{stats ? Math.floor(stats.total_amount / 10000).toLocaleString() + '万' : '集計中'}</p>
            <p class="stat-unit">{stats ? '円' : ''}</p>
          </article>

          <article class="stat-card">
            <p class="stat-label">寄付者延べ人数</p>
            <p class="stat-value">{stats ? stats.supporter_count.toLocaleString() : '集計中'}</p>
            <p class="stat-unit">{stats ? '人' : ''}</p>
          </article>
        </div>
      </section>

      <section class="section reports">
        <div class="section-head">
          <h2>助成先の声・活動レポート</h2>
        </div>

        <div class="report-grid">
          {reportsList.length > 0 ? (
            reportsList.map((report) => (
              <a href={`/reports/${report.id}`} class="report-card">
                {report.image ? (
                  <img src={report.image.url} alt={report.title} class="report-thumb" style="object-fit: cover; height: 180px; width: 100%;" />
                ) : (
                  <div class="report-thumb">画像</div>
                )}
                <div class="report-body">
                  <div class="report-meta">
                    {report.date && <span>{report.date.slice(0, 10).replace(/-/g, '.')}</span>}
                    <span class="tag">助成先レポート</span>
                  </div>
                  <h3>{report.title}</h3>
                  <p>{report.summary}</p>
                </div>
              </a>
            ))
          ) : (
            <p style="color: var(--color-gray);">レポートを準備中です。</p>
          )}
        </div>
      </section>

      <section id="news" class="section news">
        <div class="section-head">
          <h2>お知らせ</h2>
        </div>

        <div class="list-card" id="news-list">
          {newsList.map((content, index) => (
            <article class="news-item" data-news-index={index}>
              <div>
                <span class="news-date">{new Date(content.publishedAt).toISOString().slice(0, 10)}</span>
                <span class="news-tag info">お知らせ</span>
              </div>
              <a class="news-title-link" href={`/news/${content.id}`}>
                <p class="news-title">{content.title}</p>
              </a>
            </article>
          ))}
        </div>

        {newsList.length > 5 && (
          <div class="show-more-wrap">
            <button id="news-toggle-btn" class="show-more-btn" data-expanded="false">もっと見る</button>
          </div>
        )}
      </section>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page {
    padding: var(--spacing-2xl) 0;
    max-width: 1100px;
  }

  .page-header {
    margin-bottom: var(--spacing-2xl);
  }

  .page-header h1 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
    border-bottom: 3px solid var(--color-primary);
    display: inline-block;
    padding-bottom: 0.5rem;
  }

  .intro {
    max-width: 760px;
    line-height: 1.75;
    margin-top: var(--spacing-md);
    color: var(--color-dark);
  }

  .section {
    margin-bottom: var(--spacing-2xl);
  }

  .section-head h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .section-note {
    color: var(--color-gray);
    margin-top: calc(var(--spacing-sm) / 2);
    line-height: 1.6;
  }

  .stat-grid,
  .report-grid,
  .list-card {
    display: grid;
    gap: var(--spacing-lg);
  }

  .stat-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-card {
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 24px;
    padding: var(--spacing-xl);
    text-align: center;
    box-shadow: 0 12px 30px rgba(44, 62, 80, 0.05);
  }

  .stat-label {
    color: var(--color-gray);
    margin-bottom: var(--spacing-md);
    display: block;
    font-weight: 700;
  }

  .stat-value {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-unit {
    margin-top: var(--spacing-sm);
    color: var(--color-dark);
    font-weight: 700;
  }

  .report-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .report-card {
    display: block;
    color: inherit;
    text-decoration: none;
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 28px rgba(44, 62, 80, 0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .report-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(44, 62, 80, 0.12);
    color: inherit;
  }

  .report-thumb {
    min-height: 180px;
    background: rgba(94, 199, 212, 0.12);
    display: grid;
    place-items: center;
    color: var(--color-primary);
    font-weight: 700;
  }

  .report-body {
    padding: var(--spacing-lg);
  }

  .report-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(94, 199, 212, 0.18);
    color: var(--color-primary);
    font-weight: 700;
  }

  .report-body h3 {
    margin: 0 0 var(--spacing-sm) 0;
    color: var(--color-dark);
    line-height: 1.4;
  }

  .report-body p {
    margin: 0;
    line-height: 1.75;
    color: var(--color-dark);
  }

  .news .list-card,
  .media .list-card {
    border-radius: 24px;
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 10px 30px rgba(44, 62, 80, 0.05);
    overflow: hidden;
  }

  .news-item {
    padding: var(--spacing-lg);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .news-item:last-child {
    border-bottom: none;
  }

  .news-item div {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-sm);
  }

  .news-date {
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .news-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .news-tag.info {
    background: var(--color-primary);
  }

  .news-tag.event {
    background: var(--color-accent);
  }

  .news-tag.report {
    background: #6c757d;
  }

  .news-tag.media {
    background: #2c3e50;
  }

  .news-title {
    margin: 0;
    color: var(--color-dark);
    font-weight: 700;
    line-height: 1.6;
  }

  .news-title-link {
    color: inherit;
    text-decoration: none;
  }

  .news-title-link:hover .news-title {
    color: var(--color-primary);
  }

  .news-item.news-hidden {
    display: none;
  }

  .show-more-wrap {
    text-align: center;
    margin-top: var(--spacing-lg);
  }

  .show-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 2.5rem;
    border-radius: 999px;
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .show-more-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: none;
    box-shadow: none;
  }

  @media (max-width: 980px) {
    .stat-grid,
    .report-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .page {
      padding: var(--spacing-xl) 0;
    }

    .report-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  const INITIAL_SHOW = 5;
  const items = Array.from(document.querySelectorAll('#news-list .news-item')) as HTMLElement[];
  const btn = document.getElementById('news-toggle-btn') as HTMLButtonElement | null;

  if (items.length > INITIAL_SHOW) {
    items.slice(INITIAL_SHOW).forEach(item => item.classList.add('news-hidden'));

    btn?.addEventListener('click', () => {
      const expanded = btn.dataset.expanded === 'true';
      items.slice(INITIAL_SHOW).forEach(item => item.classList.toggle('news-hidden', expanded));
      btn.textContent = expanded ? 'もっと見る' : '閉じる';
      btn.dataset.expanded = String(!expanded);
    });
  }
</script>
